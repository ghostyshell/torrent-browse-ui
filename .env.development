# Development Environment Variables
REACT_APP_API_URL=http://localhost:3001
REACT_APP_BACKEND_URL=http://localhost:3001

GENERATE_SOURCEMAP=true

# Console Logs Configuration
# Show console logs during local development (production hides them by default).
# REACT_APP_SHOW_CONSOLE_LOGS=ON hides console logs (default behavior when not set)
# REACT_APP_SHOW_CONSOLE_LOGS=OFF shows all console logs
REACT_APP_SHOW_CONSOLE_LOGS=OFF