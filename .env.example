# Backend API Configuration
# This is the URL to your backend API server
REACT_APP_API_URL=http://localhost:3001

# Console Logs Configuration
# REACT_APP_SHOW_CONSOLE_LOGS=ON hides console logs (default behavior when not set)
# REACT_APP_SHOW_CONSOLE_LOGS=OFF shows all console logs
REACT_APP_SHOW_CONSOLE_LOGS=ON

# Google Cast (Chromecast) Configuration
# Optional. Defaults to Google's Default Media Receiver (CC1AD845), which plays
# standard HTTP(S) MP4/HLS streams with no custom receiver app. Only set this if
# you have registered your own styled/custom Cast receiver application.
# REACT_APP_CAST_RECEIVER_APP_ID=CC1AD845